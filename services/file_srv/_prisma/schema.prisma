// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output = "./client"
}

generator prismaClassGenerator {
  provider = "prisma-class-generator"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model File {
  uuid  String @id @default(uuid()) @db.Uuid
  name  String @db.Text

  mime String @db.Text
  size Int    @db.Integer

  folder  Folder[] @relation("file_to_folder")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([uuid, name, createdAt, updatedAt])
  @@map("file")
}

model Folder {
  uuid       String @id @default(uuid()) @db.Uuid
  name       String @db.Text

  parentUuid String? @db.Uuid
  parent     Folder? @relation(fields: [parentUuid], references: [uuid], name: "directory")
  children   Folder[] @relation("directory")

  files      File[] @relation("file_to_folder")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([uuid, name, parentUuid, createdAt, updatedAt])
  @@map("folder")
}